#include <Stepper.h>

const int stepsPerRevolution = 2048;

Stepper myStepper(stepsPerRevolution, 8, 10, 9, 11);

void setup()
{
}

void loop()
{
  myStepper.setSpeed(5);     // Slow speed
  myStepper.step(stepsPerRevolution);
  delay(1000);

  myStepper.setSpeed(15);    // Fast speed
  myStepper.step(stepsPerRevolution);
  delay(1000);
}
